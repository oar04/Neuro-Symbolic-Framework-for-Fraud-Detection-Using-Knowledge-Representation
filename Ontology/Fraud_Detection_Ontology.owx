    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_AddressHighRiskByFraudRate</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_AddressHighRiskByFraudRate</IRI>
        <Literal>Address(?a) ^ entityFraudRate(?a, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.50) -&gt; HighRiskAddress(?a)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_AddressHighRiskByFraudRate</IRI>
        <Literal>Rule_AddressHighRiskByFraudRate</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_CardHighRiskByFraudRate</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_CardHighRiskByFraudRate</IRI>
        <Literal>Card(?c) ^ entityFraudRate(?c, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.50) -&gt; HighRiskCard(?c)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_CardHighRiskByFraudRate</IRI>
        <Literal>Rule_CardHighRiskByFraudRate</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_CommunityHighRiskByFraudRate</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_CommunityHighRiskByFraudRate</IRI>
        <Literal>Community(?c) ^ communityFraudRate(?c, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.05) -&gt; HighRiskCommunity(?c)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_CommunityHighRiskByFraudRate</IRI>
        <Literal>Rule_CommunityHighRiskByFraudRate</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_DeviceHighRiskByFraudRate</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_DeviceHighRiskByFraudRate</IRI>
        <Literal>Device(?d) ^ entityFraudRate(?d, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.80) -&gt; HighRiskDevice(?d)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_DeviceHighRiskByFraudRate</IRI>
        <Literal>Rule_DeviceHighRiskByFraudRate</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_EmailDomainHighRiskByFraudRate</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_EmailDomainHighRiskByFraudRate</IRI>
        <Literal>EmailDomain(?e) ^ entityFraudRate(?e, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.50) -&gt; HighRiskEmailDomain(?e)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_EmailDomainHighRiskByFraudRate</IRI>
        <Literal>Rule_EmailDomainHighRiskByFraudRate</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_ModelFlaggedByRiskScore</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_ModelFlaggedByRiskScore</IRI>
        <Literal>Transaction(?t) ^ modelRiskScore(?t, ?s) ^ swrlb:greaterThanOrEqual(?s, 0.80) -&gt; ModelFlaggedTransaction(?t)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_ModelFlaggedByRiskScore</IRI>
        <Literal>Rule_ModelFlaggedByRiskScore</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_RequiresInvestigation</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_RequiresInvestigation</IRI>
        <Literal>StronglySuspiciousTransaction(?t) -&gt; RequiresInvestigation(?t)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_RequiresInvestigation</IRI>
        <Literal>Rule_RequiresInvestigation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_StrongSuspicionByMultipleHighRiskEntities</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_StrongSuspicionByMultipleHighRiskEntities</IRI>
        <Literal>Transaction(?t) ^ highRiskEntityCount(?t, ?c) ^ swrlb:greaterThanOrEqual(?c, 2) -&gt; StronglySuspiciousTransaction(?t)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_StrongSuspicionByMultipleHighRiskEntities</IRI>
        <Literal>Rule_StrongSuspicionByMultipleHighRiskEntities</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_SuspicionByMaxEntityFraudRate</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_SuspicionByMaxEntityFraudRate</IRI>
        <Literal>Transaction(?t) ^ maxEntityFraudRate(?t, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.50) -&gt; SemanticallySuspiciousTransaction(?t)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_SuspicionByMaxEntityFraudRate</IRI>
        <Literal>Rule_SuspicionByMaxEntityFraudRate</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_TransactionSuspiciousByHighRiskCommunity</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_TransactionSuspiciousByHighRiskCommunity</IRI>
        <Literal>Transaction(?t) ^ belongsToCommunity(?t, ?c) ^ HighRiskCommunity(?c) -&gt; GraphFlaggedTransaction(?t)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_TransactionSuspiciousByHighRiskCommunity</IRI>
        <Literal>Rule_TransactionSuspiciousByHighRiskCommunity</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#implementationNote"/>
        <IRI>#Rule_TransactionSuspiciousByHighRiskDevice</IRI>
        <Literal>Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="#swrlRuleText"/>
        <IRI>#Rule_TransactionSuspiciousByHighRiskDevice</IRI>
        <Literal>Transaction(?t) ^ usedDevice(?t, ?d) ^ HighRiskDevice(?d) -&gt; SemanticallySuspiciousTransaction(?t)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Rule_TransactionSuspiciousByHighRiskDevice</IRI>
        <Literal>Rule_TransactionSuspiciousByHighRiskDevice</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
