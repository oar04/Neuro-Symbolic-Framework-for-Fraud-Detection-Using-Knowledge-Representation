  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rule_CardHighRiskByFraudRate</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Rule_CommunityHighRiskByFraudRate">
