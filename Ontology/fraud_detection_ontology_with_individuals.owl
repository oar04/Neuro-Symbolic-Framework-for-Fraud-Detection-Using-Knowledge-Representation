  <swrlRuleText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Device(?d) ^ entityFraudRate(?d, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.80) -&gt; HighRiskDevice(?d)</swrlRuleText>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rule_DeviceHighRiskByFraudRate</rdfs:label>
