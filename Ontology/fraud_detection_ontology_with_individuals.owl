  <swrlRuleText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Community(?c) ^ communityFraudRate(?c, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.05) -&gt; HighRiskCommunity(?c)</swrlRuleText>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rule_CommunityHighRiskByFraudRate</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Rule_DeviceHighRiskByFraudRate">
  <rdf:type rdf:resource="#ThresholdPolicy"/>
