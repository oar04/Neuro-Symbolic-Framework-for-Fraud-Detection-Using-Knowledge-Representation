<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.semanticweb.org/osman/fraud-ontology"
         xmlns="http://www.semanticweb.org/osman/fraud-ontology#"
         xmlns:swrl="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#">

<owl:Ontology rdf:about="http://www.semanticweb.org/osman/fraud-ontology">
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ontology for Neo4j graph-enhanced fraud detection, XAI, model comparison, and semantic reasoning.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graph-Enhanced Fraud Detection Ontology</rdfs:label>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#belongsToCommunity">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Community"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a transaction to its Louvain community.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">belongsToCommunity</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#evidenceRefersToCommunity">
  <rdfs:domain rdf:resource="#RiskEvidence"/>
  <rdfs:range rdf:resource="#Community"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links evidence to the relevant community.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">evidenceRefersToCommunity</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#evidenceRefersToEntity">
  <rdfs:domain rdf:resource="#RiskEvidence"/>
  <rdfs:range rdf:resource="#Entity"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links evidence to the relevant entity.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">evidenceRefersToEntity</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#explainsTransaction">
  <rdfs:domain rdf:resource="#RiskExplanation"/>
  <rdfs:range rdf:resource="#Transaction"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links an explanation to the transaction it explains.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">explainsTransaction</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasGraphEvidence">
  <rdfs:subPropertyOf rdf:resource="#hasRiskEvidence"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#GraphEvidence"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a transaction to graph-derived evidence.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasGraphEvidence</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasModelEvidence">
  <rdfs:subPropertyOf rdf:resource="#hasRiskEvidence"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#ModelEvidence"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a transaction to model evidence.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasModelEvidence</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRiskEvidence">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#RiskEvidence"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a transaction to evidence supporting its risk classification.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasRiskEvidence</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRiskExplanation">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#RiskExplanation"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a transaction to a human-readable explanation.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasRiskExplanation</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSemanticEvidence">
  <rdfs:subPropertyOf rdf:resource="#hasRiskEvidence"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#SemanticEvidence"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Links a transaction to semantic evidence.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">hasSemanticEvidence</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#sharesInfrastructureWith">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Transaction"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicates transactions share at least one entity.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sharesInfrastructureWith</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedAddr1">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Addr1"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_ADDR1</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_ADDR1 relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedAddr1</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedAddr2">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Addr2"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_ADDR2</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_ADDR2 relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedAddr2</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedBrowser">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Browser"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_BROWSER</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_BROWSER relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedBrowser</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedCard1">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Card1"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_CARD1</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_CARD1 relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedCard1</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedCard2">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Card2"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_CARD2</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_CARD2 relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedCard2</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedCard3">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Card3"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_CARD3</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_CARD3 relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedCard3</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedCard5">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Card5"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_CARD5</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_CARD5 relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedCard5</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedCardNetwork">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#CardNetwork"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_CARD_NETWORK</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_CARD_NETWORK relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedCardNetwork</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedCardType">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#CardType"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_CARD_TYPE</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_CARD_TYPE relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedCardType</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedDevice">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Device"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_DEVICE</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_DEVICE relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedDevice</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedDeviceType">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#DeviceType"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_DEVICE_TYPE</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_DEVICE_TYPE relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedDeviceType</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedOperatingSystem">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#OperatingSystem"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_OPERATING_SYSTEM</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_OPERATING_SYSTEM relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedOperatingSystem</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedPayerEmailDomain">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#PayerEmailDomain"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_PAYER_EMAIL_DOMAIN</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_PAYER_EMAIL_DOMAIN relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedPayerEmailDomain</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedProduct">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Product"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_PRODUCT</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_PRODUCT relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedProduct</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedReceiverEmailDomain">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#ReceiverEmailDomain"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_RECEIVER_EMAIL_DOMAIN</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_RECEIVER_EMAIL_DOMAIN relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedReceiverEmailDomain</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usedScreenResolution">
  <rdfs:subPropertyOf rdf:resource="#usesEntity"/>
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#ScreenResolution"/>
  <neo4jRelationshipType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">USED_SCREEN_RESOLUTION</neo4jRelationshipType>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matches Neo4j USED_SCREEN_RESOLUTION relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usedScreenResolution</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usesEntity">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="#Entity"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Generic transaction-to-entity relationship.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">usesEntity</rdfs:label>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#communityFraudRate">
  <rdfs:domain rdf:resource="#Community"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fraud rate within a graph community.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">communityFraudRate</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#communityId">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">communityId</neo4jPropertyName>
  <xaiPurpose rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graph XAI: community membership used to contextualise risk.</xaiPurpose>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Louvain community ID from Neo4j GDS.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">communityId</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#communitySize">
  <rdfs:domain rdf:resource="#Community"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of transactions in a community.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">communitySize</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#degree">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">degree</neo4jPropertyName>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Node degree feature.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">degree</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#entityFraudRate">
  <rdfs:domain rdf:resource="#Entity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">entity_fraud_rate</neo4jPropertyName>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fraud rate calculated for an entity.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">entityFraudRate</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#entityId">
  <rdfs:domain rdf:resource="#Entity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier for entity individuals.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">entityId</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#evidenceStrength">
  <rdfs:domain rdf:resource="#RiskEvidence"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numerical strength of evidence.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">evidenceStrength</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#explanationText">
  <rdfs:domain rdf:resource="#RiskExplanation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Human-readable XAI explanation text.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">explanationText</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#fraudTransactionCount">
  <rdfs:domain rdf:resource="#Entity"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fraud_tx</neo4jPropertyName>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fraudulent transactions linked to an entity.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fraudTransactionCount</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#highRiskEntityCount">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">high_risk_entity_count</neo4jPropertyName>
  <xaiPurpose rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feature-level XAI: number of independent high-risk linked entities.</xaiPurpose>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Count of linked high-risk entities.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">highRiskEntityCount</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#isFraud">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is_fraud</neo4jPropertyName>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fraud label from the dataset.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">isFraud</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#maxEntityFraudRate">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">max_entity_fraud_rate</neo4jPropertyName>
  <xaiPurpose rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Feature-level XAI: highest fraud rate among connected entities.</xaiPurpose>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Maximum fraud rate of connected entities.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">maxEntityFraudRate</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#modelRiskScore">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Generic model fraud probability.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">modelRiskScore</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#neuralNetworkScore">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Neural network fraud probability.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">neuralNetworkScore</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#pageRank">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  <neo4jPropertyName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pagerank</neo4jPropertyName>
  <xaiPurpose rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graph XAI: centrality/influence of a transaction or entity in the graph.</xaiPurpose>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PageRank score from Neo4j GDS.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pageRank</rdfs:label>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#randomForestScore">
  <rdfs:domain rdf:resource="#Transaction"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
