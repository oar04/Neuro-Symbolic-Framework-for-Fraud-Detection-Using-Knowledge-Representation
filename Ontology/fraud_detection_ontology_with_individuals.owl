<owl:NamedIndividual rdf:about="#Rule_ModelFlaggedByRiskScore">
  <rdf:type rdf:resource="#ThresholdPolicy"/>
  <implementationNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</implementationNote>
  <swrlRuleText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transaction(?t) ^ modelRiskScore(?t, ?s) ^ swrlb:greaterThanOrEqual(?s, 0.80) -&gt; ModelFlaggedTransaction(?t)</swrlRuleText>
