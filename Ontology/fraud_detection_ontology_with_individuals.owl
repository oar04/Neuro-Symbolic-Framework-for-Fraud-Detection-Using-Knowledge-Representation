  <swrlRuleText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transaction(?t) ^ highRiskEntityCount(?t, ?c) ^ swrlb:greaterThanOrEqual(?c, 2) -&gt; StronglySuspiciousTransaction(?t)</swrlRuleText>
