<owl:NamedIndividual rdf:about="#Rule_AddressHighRiskByFraudRate">
  <rdf:type rdf:resource="#ThresholdPolicy"/>
  <implementationNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Copy this rule into Protégé SWRLTab if executable SWRL reasoning is required.</implementationNote>
  <swrlRuleText rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Address(?a) ^ entityFraudRate(?a, ?r) ^ swrlb:greaterThanOrEqual(?r, 0.50) -&gt; HighRiskAddress(?a)</swrlRuleText>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rule_AddressHighRiskByFraudRate</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Rule_CardHighRiskByFraudRate">
  <rdf:type rdf:resource="#ThresholdPolicy"/>
